# ==========================================
# 依天学境 (YiTian Learning Cosmos) 环境配置文件
# ==========================================

# ==========================================
# 基础配置
# ==========================================

# 项目名称
PROJECT_NAME=YiTianLearningCosmos

# 调试模式 (True/False)
DEBUG=True

# 日志级别 (DEBUG/INFO/WARNING/ERROR)
LOG_LEVEL=INFO

# ==========================================
# 大语言模型 API 配置
# ==========================================

# DashScope API 密钥 (阿里云通义千问)
# 获取地址: https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY=your_dashscope_api_key_here

# DeepSeek API 配置
# 获取地址: https://platform.deepseek.com/
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com

# ==========================================
# 文档解析服务配置
# ==========================================

# Llama Cloud API 密钥 (文档解析服务)
# 获取地址: https://cloud.llamaindex.ai/
LLAMA_CLOUD_API_KEY=your_llama_cloud_api_key_here

# ==========================================
# 本地模型配置
# ==========================================

# 本地大语言模型路径 (可选，用于离线部署)
# 示例: /models/Qwen/Qwen2-7B-Instruct
LLM_MODEL_PATH=

# 本地嵌入模型路径 (可选)
# 示例: /models/BAAI/bge-large-zh-v1.5
EMBED_PATH=

# 存储目录路径
# 用于存储向量数据库和缓存文件
STORAGE_DIR=./storage

# RAG 查询引擎专用路径配置
# 大语言模型路径
LLM_PATH=C:\\study\\llm_application\\juke6\\myprojects_juke\\CivilMind\\models\\LiquidAI\\LFM2-1___2B
# 嵌入模型路径
EMBED_PATH=C:\\study\\llm_application\\juke6\\myprojects_juke\\CivilMind\\models\\BAAI\\bge-base-zh-v1.5
# 向量存储目录
STORAGE_DIR=C:\\study\\llm_application\\juke6\\myprojects_juke\\CivilMind\\storage_faiss

# ==========================================
# 智能体服务配置
# ==========================================

# 各智能体服务URL地址
FILE_PARSE_AGENT_URL=http://localhost:10001
CODE_AGENT_URL=http://localhost:10002
DOCTOR_AGENT_URL=http://localhost:10003
SEARCH_AGENT_URL=http://localhost:10004

# ==========================================
# 客户端配置
# ==========================================

# Web客户端端口
CLIENT_WEB_PORT=8030

# CLI客户端配置
CLI_BEARER_TOKEN=your_bearer_token_here
CLI_SESSION_ID=default_session

# ==========================================
# 数据库配置 (如需要)
# ==========================================

# 数据库URL (可选)
DATABASE_URL=sqlite:///./yi_tian_learning.db

# Search Agent数据库配置
SEARCH_DB_HOST=localhost
SEARCH_DB_PORT=5432
SEARCH_DB_NAME=search_agent_database
SEARCH_DB_USER=postgres
SEARCH_DB_PASSWORD=postgres

# ==========================================
# 其他可选配置
# ==========================================

# 最大并发连接数
MAX_CONCURRENT_REQUESTS=10

# 请求超时时间(秒)
REQUEST_TIMEOUT=300

# 对话历史最大长度
MAX_HISTORY_LENGTH=20

# 文件上传大小限制(MB)
MAX_FILE_SIZE=50

# ==========================================
# 开发环境专用配置
# ==========================================

# 开发模式下的额外调试信息
DEV_MODE_VERBOSE=False

# 测试用的模拟数据开关
USE_MOCK_DATA=False